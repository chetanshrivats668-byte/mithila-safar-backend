# =====================================
# SERVER CONFIG
# =====================================

# Port the backend server listens on (default: 3001)
PORT=3001

# =====================================
# FIREBASE CONFIG
# =====================================
# All Firebase config values are REQUIRED.
# They are exposed to the frontend via GET /api/config for Firebase Storage
# and Firebase App initialization.
#
# Get these from: Firebase Console → Project Settings → General → Web Apps

FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=1:your_project_id:web:your_web_hash

# =====================================
# AUTH CONFIG
# =====================================

# JWT secret used to sign admin and collaborator tokens.
# REQUIRED — generate a strong random string for production.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# =====================================
# GOOGLE OAUTH
# =====================================

# Google OAuth Client ID for "Sign in with Google" on the frontend.
# REQUIRED — server will fail to start without it.
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# This is a public client ID (safe to embed in frontend code).
GOOGLE_CLIENT_ID=494833578713-r3tbr8e1bquphe3r84pbdeba5no7tqmj.apps.googleusercontent.com

# =====================================
# RAZORPAY CONFIG
# =====================================
# Both Razorpay keys are REQUIRED.
# Get from: Razorpay Dashboard → Settings → API Keys
#
# RAZORPAY_KEY_ID is also exposed to the frontend via GET /api/config
# for Razorpay Checkout integration.

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# =====================================
# OTP / SMS CONFIG
# =====================================

# MSG91 auth key used by the backend to verify widget access tokens.
# REQUIRED for the phone verification widget flow used in signup/profile/login.
MSG91_AUTH_KEY=your_msg91_auth_key

# MSG91 widget configuration exposed to the frontend via GET /api/config.
# REQUIRED for the older MSG91 widget-based OTP flow.
MSG91_WIDGET_ID=your_msg91_widget_id
MSG91_WIDGET_TOKEN_AUTH=your_msg91_widget_token_auth

# Optional MSG91 OTP/SMS template settings for other flows.
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=YTRIPT
MSG91_FLOW_ID=your_general_flow_id

# Phone number for admin SMS notifications (e.g., new order alerts).
# Optional — if not set, notifications are skipped.
ADMIN_PHONE=+919XXXXXXXXX

# =====================================
# SMTP / EMAIL CONFIG
# =====================================
# Credentials for Nodemailer to send OTP and notifications via email.
# Optional — if not set, OTP will be logged to console in dev mode.
# Can use standard SMTP providers (Gmail, Resend, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Yatri Point" <your_email@gmail.com>

# Development OTP bypass — set to "true" to skip actual SMS sending.
# When enabled, OTP "112233" will work for all verification flows.
# ⚠️ NEVER set this to "true" in production.
DEV_OTP_BYPASS=false

# =====================================
# ADMIN CONFIG
# =====================================
# Both admin credentials are REQUIRED.
# Used for login at /admin-panel.html
# Change these immediately after first deployment.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_admin_password

# =====================================
# COLLABORATOR SYSTEM
# =====================================
# The collaborator (vendor/partner) system uses the same JWT_SECRET
# and Firestore database. No additional env vars are required
# beyond the Firebase and JWT config above.

# =====================================
# REDIS CONFIG (Production Only)
# =====================================
# Required in production. Used for caching and rate limiting.
# Example: redis://default:password@host:port or rediss://... for TLS
REDIS_URL=your_redis_connection_url
